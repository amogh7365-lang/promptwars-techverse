        <style>
            @charset "UTF-8";.SlotButton__button {
                position: relative;
                display: inline-block;
                color: inherit;
                text-decoration: none;
                overflow: hidden;
                transition: background-color .3s cubic-bezier(.25,.46,.45,.94),border-color .3s cubic-bezier(.25,.46,.45,.94)
            }

            .SlotButton__button:hover .SlotButton__text_wrapper {
                transform: translateY(-100%)
            }

            .SlotButton__button:hover .SlotButton__text_hover {
                opacity: 1
            }

            .SlotButton__button:hover .SlotButton__text {
                opacity: 0
            }

            .SlotButton__text_wrapper {
                position: relative;
                display: block;
                transition: transform .3s cubic-bezier(.25,.46,.45,.94)
            }

            .SlotButton__text {
                display: block;
                color: inherit;
                transition: color .3s cubic-bezier(.25,.46,.45,.94),opacity .3s cubic-bezier(.25,.46,.45,.94)
            }

            .SlotButton__text_hover {
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                display: block;
                color: #000;
                opacity: 0;
                transition: opacity .3s cubic-bezier(.25,.46,.45,.94)
            }
        </style>
