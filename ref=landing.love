        <style>
            @charset "UTF-8";* {
                box-sizing: border-box;
                padding: 0;
                margin: 0
            }

            html,body {
                font-family: Hiragino Kaku Gothic ProN,メイリオ,sans-serif;
                text-size-adjust: 100%;
                -webkit-font-smoothing: antialiased;
                -webkit-tap-highlight-color: transparent;
                color: #fff;
                background-color: #000
            }

    
        /* Hide UnicornStudio branding watermark/badges */
        a[href*="unicorn.studio"],
        div[class*="unicornstudio"],
        [id*="unicornstudio"],
        div[class*="us-watermark"],
        div[class*="us-badge"],
        div:has(> a[href*="unicorn.studio"]) {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
            pointer-events: none !important;
        }

        /* Force UnicornStudio container and canvas to cover the full viewport tab */
        div[data-us-project] {
            display: none !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            z-index: -2 !important;
            pointer-events: none !important;
            overflow: hidden !important;
        }
        div[data-us-project] canvas {
            width: 100vw !important;
            height: 100vh !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            object-fit: cover !important;
        }


        /* Hide original WebGL canvases and overlays */
        #gl-canvas, 
        .Layout__gl, 
        .GLCanvas__container {
            display: none !important;
            opacity: 0 !important;
            pointer-events: none !important;
        }

        /* Hide UnicornStudio branding watermark/badges */
        a[href*="unicorn.studio"],
        div[class*="unicornstudio"],
        [id*="unicornstudio"],
        div[class*="us-watermark"],
        div[class*="us-badge"],
        div:has(> a[href*="unicorn.studio"]) {
            display: none !important;
            opacity: 0 !important;
            visibility: hidden !important;
            pointer-events: none !important;
        }

        /* Force UnicornStudio container and canvas to cover the full viewport tab */
        div[data-us-project] {
            display: none !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            z-index: -2 !important;
            pointer-events: none !important;
            overflow: hidden !important;
        }
        div[data-us-project] canvas {
            width: 100vw !important;
            height: 100vh !important;
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            object-fit: cover !important;
            filter: brightness(1.25) contrast(1.05) !important; /* Brighter overlay */
        }

        body {
                position: relative
            }

            body[data-modal=true] {
                overflow-y: hidden
            }

            img {
                max-width: 100%;
                vertical-align: top
            }

            li {
                list-style: none
            }

            a {
                text-decoration: none;
                color: #fff
            }

            button {
                appearance: none;
                cursor: pointer;
                user-select: none;
                outline: none;
                background: none;
                border: none;
                color: #363b46
            }

            input,textarea {
                appearance: none;
                user-select: all;
                outline: none;
                border: none
            }

            svg {
                display: block
            }

            [data-media=max-xl] {
                display: none
            }

            @media only screen and (min-width: 950px) {
                [data-media=max-xl] {
                    display:block
                }
            }

            [data-media=max-md] {
                display: none
            }

            @media only screen and (min-width: 769px) {
                [data-media=max-md] {
                    display:block
                }
            }

            @media only screen and (min-width: 950px) {
                [data-media=min-xl] {
                    display:none
                }
            }

            @media not screen and (min-width: 950px) {
                [data-media=min-xl] {
                    display:block
                }
            }

            [data-media=min-md] {
                display: none
            }

            @media not screen and (min-width: 769px) {
                [data-media=min-md] {
                    display:block
                }
            }

            [data-media=max-xl-inline] {
                display: none
            }

            @media only screen and (min-width: 950px) {
                [data-media=max-xl-inline] {
                    display:inline
                }
            }

            @media only screen and (min-width: 950px) {
                [data-media=min-xl-inline] {
                    display:none
                }
            }

            @media not screen and (min-width: 950px) {
                [data-media=min-xl-inline] {
                    display:inline
                }
            }

            .lenis.lenis-smooth {
                scroll-behavior: auto!important
            }

            .lenis.lenis-smooth [data-lenis-prevent] {
                overscroll-behavior: contain
            }

            .lenis.lenis-stopped {
                overflow: hidden
            }

            .lenis.lenis-smooth iframe {
                pointer-events: none
            }
